{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LabeledTransactionRecord",
  "type": "object",
  "required": [
    "record_id",
    "features",
    "labels"
  ],
  "properties": {
    "record_id": {
      "type": "string"
    },
    "features": {
      "type": "object",
      "required": [
        "input_text",
        "source",
        "currency",
        "transaction_date"
      ],
      "properties": {
        "input_text": {
          "type": "string"
        },
        "normalized_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string",
          "enum": [
            "manual_text",
            "csv_upload",
            "pdf_upload",
            "upload",
            "bank_feed"
          ]
        },
        "currency": {
          "type": "string"
        },
        "transaction_date": {
          "type": "string",
          "format": "date"
        },
        "amount_mentions": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object"
          }
        },
        "date_mentions": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object"
          }
        },
        "party_mentions": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object"
          }
        },
        "quantity_mentions": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object"
          }
        },
        "amount": {
          "type": [
            "number",
            "null"
          ]
        },
        "counterparty": {
          "type": [
            "string",
            "null"
          ]
        },
        "normalized_description": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "labels": {
      "type": "object",
      "required": [
        "intent_label",
        "bank_category",
        "cca_class_match",
        "entities"
      ],
      "properties": {
        "intent_label": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "asset_purchase",
            "software_subscription",
            "rent_expense",
            "meals_entertainment",
            "professional_fees",
            "bank_fee",
            "transfer",
            "bank_transaction",
            "general_expense",
            null
          ]
        },
        "bank_category": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "transfer",
            "equipment",
            "software_subscription",
            "rent",
            "meals_entertainment",
            "professional_fees",
            "bank_fees",
            null
          ]
        },
        "cca_class_match": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "class_50",
            "class_8",
            null
          ]
        },
        "entities": {
          "type": "object",
          "properties": {
            "amount": {
              "type": [
                "number",
                "null"
              ]
            },
            "vendor": {
              "type": [
                "string",
                "null"
              ]
            },
            "asset_name": {
              "type": [
                "string",
                "null"
              ]
            },
            "quantity": {
              "type": [
                "integer",
                "null"
              ]
            },
            "mentioned_date": {
              "type": [
                "string",
                "null"
              ],
              "format": "date"
            },
            "transfer_destination": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "entity_spans": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object",
            "required": [
              "label",
              "text",
              "start",
              "end"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "start": {
                "type": "integer",
                "minimum": 0
              },
              "end": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
